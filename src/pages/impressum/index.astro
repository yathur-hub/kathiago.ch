---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Impressum">
  <div class="section-spacing max-w-3xl mx-auto px-4">
    <h1 class="text-4xl font-bold mb-12">Impressum</h1>
    
    <div class="space-y-12">
      <section>
        <h2 class="text-2xl font-semibold mb-4">Anbieter</h2>
        <p>
          Kathiago GmbH<br />
          Splügenstrasse 11<br />
          8002 Zürich<br />
          Schweiz
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold mb-4">Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:info@kathiago.ch" class="text-primary hover:underline">info@kathiago.ch</a>
        </p>
        <p class="mt-4">
          Ansprechperson:<br />
          Tiago Garcia
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold mb-4">Vertretungsberechtigte Personen</h2>
        <p>
          Kathirsan Kathirgamanathan<br />
