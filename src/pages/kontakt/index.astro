---
import Layout from '../../layouts/Layout.astro';
import HubSpotForm from '../../components/HubSpotForm.astro';
---

<Layout title="Kontakt">
  <section class="section-spacing">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h1 class="text-4xl md:text-6xl mb-6">Lassen Sie uns <span class="text-primary">sprechen</span>.</h1>
          <p class="text-xl text-slate-600 mb-10">
            Haben Sie Fragen zu unseren Programmen oder benötigen Sie eine massgeschneiderte Lösung für Ihr Unternehmen? Wir sind für Sie da.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary">
                &phone;
              </div>
              <span class="font-medium">+41 44 123 45 67</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center text-primary">
                &commat;
              </div>
              <span class="font-medium">info@kathiago.ch</span>
            </div>
          </div>
        </div>
        
        <div class="card p-8 bg-surface">
          <h2 class="text-2xl mb-6">Kontaktformular</h2>
          <HubSpotForm portalId="456789" formId="contact-form-id" />
        </div>
      </div>
    </div>
  </section>
</Layout>
