---
import Layout from '../../../layouts/Layout.astro';
--- 

<Layout title="CICERO Weiterbildung">
  <!-- 1. HERO -->
  <section class="relative bg-navy pt-20 pb-24 md:pt-28 md:pb-32 overflow-hidden text-white">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-primary/10 -skew-x-12 transform translate-x-1/4 pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <div class="inline-block px-3 py-1 rounded-full bg-accent/20 text-accent text-xs font-bold uppercase tracking-widest mb-6">
            CICERO
          </div>
          <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-[0.9] tracking-tight">
            Cicero
          </h1>
          <p class="text-xl md:text-2xl font-medium mb-10 leading-relaxed opacity-90">
            Effiziente Erfüllung der regulatorischen Weiterbildungspflicht für Finanzberater.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/kontakt/" class="btn-primary text-lg px-8 py-4 shadow-lg shadow-primary/20">CICERO Punkte sichern</a>
            <a href="/kontakt/" class="bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-md font-bold text-lg transition-colors">Weiterbildungsplan erstellen</a>
          </div>
        </div>

        <div class="hidden lg:block lg:col-span-5 bg-white p-8 rounded-2xl shadow-2xl">
          <img 
            src="https://www.cicero.ch/_Resources/Persistent/f/0/b/f/f0bfddad37d4701601f549b10831c1af77753737/Cicero_Logo_neg_BlueDark_RGB.svg" 
            alt="Cicero Logo" 
            class="w-full max-w-md mx-auto"
            referrerpolicy="no-referrer"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. WARUM CICERO? -->
  <section class="section-spacing bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl mb-8 text-navy">Weiterbildung ist regulatorisch verankert</h2>
          <div class="space-y-6 text-slate-600">
            <p>Die Anforderungen an Berater steigen kontinuierlich – nicht nur fachlich, sondern auch regulatorisch.</p>
            <p>CICERO definiert den Standard für:</p>
            <ul class="list-disc pl-5 space-y-2">
              <li>Erfassung der Weiterbildung</li>
              <li>Anerkennung von Inhalten</li>
              <li>Dokumentation der Kompetenzentwicklung</li>
            </ul>
          </div>
        </div>
        <div class="bg-surface p-8 rounded-2xl border border-primary/10">
          <blockquote class="italic text-2xl text-navy font-display">
            „Kompetenz ist nicht das, was du einmal gelernt hast – sondern das, was du kontinuierlich weiterentwickelst.“
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. POSITIONIERUNG IM SYSTEM -->
  <section class="section-spacing bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Das Bindeglied zwischen Ausbildung und Praxis</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Sicherstellung</h3>
          <p class="text-slate-600">Aktualität des Wissens durch kontinuierliche Updates.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Absicherung</h3>
          <p class="text-slate-600">Regulatorische Konformität durch dokumentierte Leistungen.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Entwicklung</h3>
          <p class="text-slate-600">Strukturierte Kompetenzentwicklung über die gesamte Laufbahn.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. ZIELGRUPPE -->
  <section class="section-spacing bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Für aktive Berater im Markt</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 bg-surface rounded-2xl border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Typische Profile</h3>
          <ul class="list-disc pl-5 space-y-2 text-slate-600">
            <li>Versicherungsvermittler</li>
            <li>Finanzberater</li>
            <li>Vermögensberater</li>
            <li>Kundenberater in Banken</li>
          </ul>
        </div>
        <div class="p-8 bg-surface rounded-2xl border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Besonders relevant für</h3>
          <ul class="list-disc pl-5 space-y-2 text-slate-600">
            <li>Berater mit CICERO-Registrierung</li>
            <li>Personen mit Weiterbildungspflicht</li>
            <li>Unternehmen mit Weiterbildungsanforderungen</li>
          </ul>
        </div>
      </div>
      <div class="mt-8 p-6 bg-navy text-white rounded-2xl text-center">
        <p class="text-lg font-medium">CICERO ist kein Einstiegsprogramm. Es ist ein System für aktive Marktteilnehmer.</p>
      </div>
    </div>
  </section>

  <!-- 5. KOMPETENZLOGIK -->
  <section class="section-spacing bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Weiterbildung mit System statt Einzelmassnahmen</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: "Kontinuierliche Entwicklung", items: ["regelmässige Wissensaktualisierung", "Erweiterung bestehender Kompetenzen"] },
          { title: "Nachweisbarkeit", items: ["dokumentierte Weiterbildungspunkte", "nachvollziehbare Lernhistorie"] },
          { title: "Relevanz", items: ["Fokus auf praxisnahe Inhalte", "direkte Anwendbarkeit im Alltag"] }
        ].map(item => (
          <div class="p-8 bg-white rounded-2xl border border-slate-100 shadow-sm">
            <h3 class="font-bold text-navy mb-4">{item.title}</h3>
            <ul class="list-disc pl-5 space-y-2 text-slate-600 text-sm">
              {item.items.map(sub => <li>{sub}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 p-8 bg-white rounded-2xl border border-primary/20 text-center">
        <p class="text-xl font-bold text-navy">Das Ziel ist nicht „mehr Wissen“. Das Ziel ist relevantes Wissen zur richtigen Zeit.</p>
      </div>
    </div>
  </section>

  <!-- 6. INHALTLICHE AUSRICHTUNG -->
  <section class="section-spacing bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Was wird vermittelt</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {["regulatorische Updates (FIDLEG, FINIG etc.)", "neue Produkte und Marktveränderungen", "Beratungskompetenz und Kundeninteraktion", "digitale Entwicklungen im Finanzbereich", "Risiko- und Compliance-Themen"].map(item => (
          <div class="p-6 bg-surface rounded-xl border border-slate-100 flex items-center">
            <span class="text-accent mr-3">✓</span>
            <span class="font-bold text-navy">{item}</span>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-slate-600 italic">Die Inhalte sind bewusst dynamisch und werden laufend angepasst.</p>
    </div>
  </section>

  <!-- 7. FORMAT -->
  <section class="section-spacing bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl mb-8 text-navy">Flexibel integrierbar in den Alltag</h2>
          <p class="text-slate-600 mb-6">Die CICERO-Weiterbildungen sind so aufgebaut, dass sie sich in den Arbeitsalltag integrieren lassen.</p>
          <div class="grid grid-cols-2 gap-4">
            {["kompakte Modules", "Online-Sessions", "themenspezifische Updates", "kombinierbar mit anderen Lehrgängen"].map(item => (
              <div class="p-4 bg-white rounded-lg border border-slate-100 text-sm font-bold text-navy text-center">{item}</div>
            ))}
          </div>
        </div>
        <div class="p-8 bg-white rounded-2xl border border-primary/20 shadow-lg text-center">
          <p class="text-xl font-bold text-navy mb-2">Fokus auf Effizienz</p>
          <p class="text-accent font-bold text-2xl">→ maximaler Nutzen bei minimalem Zeitaufwand</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. STRATEGISCHE RELEVANZ -->
  <section class="section-spacing bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Warum CICERO entscheidend ist</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: "Regulatorische Sicherheit", items: ["Erfüllung von Weiterbildungspflichten", "Nachweis gegenüber Institutionen"] },
          { title: "Marktpositionierung", items: ["signalisiert Professionalität", "zeigt kontinuierliche Entwicklung"] },
          { title: "Qualität der Beratung", items: ["aktuelles Wissen", "bessere Entscheidungsgrundlagen"] }
        ].map(item => (
          <div class="p-8 bg-surface rounded-2xl border border-slate-100">
            <h3 class="font-bold text-navy mb-4">{item.title}</h3>
            <ul class="list-disc pl-5 space-y-2 text-slate-600 text-sm">
              {item.items.map(sub => <li>{sub}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <p class="text-lg font-bold text-navy">Berater ohne kontinuierliche Weiterbildung verlieren langfristig an Relevanz.</p>
      </div>
    </div>
  </section>

  <!-- 9. EINORDNUNG IM WEITERBILDUNGSPFAD -->
  <section class="section-spacing bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl mb-8 text-navy">Wie CICERO in dein System passt</h2>
          <p class="text-slate-600 mb-6">CICERO ergänzt bestehende Ausbildungen. Es ist kein Ersatz, sondern die Fortsetzung.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm">
          <h3 class="font-bold text-navy mb-4">Typische Kombinationen</h3>
          <div class="space-y-2">
            {["VBV + CICERO", "Vermögensberater IAF + CICERO", "Finanzberater IAF + CICERO", "Eidg. Finanzplaner + CICERO"].map(item => (
              <div class="p-3 bg-surface rounded-lg font-bold text-navy">{item}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. POSITIONIERUNGSEFFEKT -->
  <section class="section-spacing bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl mb-12 text-navy text-center">Was sich für dich verändert</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 bg-surface rounded-2xl border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Mit strukturierter Weiterbildung</h3>
          <ul class="list-disc pl-5 space-y-2 text-slate-600">
            <li>bleibst du fachlich aktuell</li>
            <li>erfüllst du regulatorische Anforderungen</li>
            <li>stärkst du deine Marktposition</li>
          </ul>
        </div>
        <div class="p-8 bg-surface rounded-2xl border border-slate-100">
          <h3 class="font-bold text-navy mb-4">Das führt zu</h3>
          <ul class="list-disc pl-5 space-y-2 text-slate-600">
            <li>höherem Vertrauen</li>
            <li>besserer Beratungsqualität</li>
            <li>nachhaltiger Entwicklung</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. ABSCHLUSS -->
  <section class="py-24 bg-navy text-white text-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-4xl md:text-5xl mb-8 text-white">Weiterbildung endet nicht</h2>
      <div class="max-w-2xl mx-auto space-y-6 mb-12 opacity-90">
        <p>Der Finanzmarkt verändert sich ständig.</p>
        <p>Wer stehen bleibt, verliert.</p>
        <p>CICERO stellt sicher, dass:</p>
        <ul class="list-none space-y-2">
          <li>du dich kontinuierlich weiterentwickelst</li>
          <li>deine Kompetenz sichtbar bleibt</li>
          <li>deine Beratung relevant bleibt</li>
        </ul>
      </div>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/kontakt/" class="bg-accent hover:bg-amber-600 text-white px-8 py-4 rounded-md font-bold text-lg transition-colors">CICERO Punkte sichern</a>
        <a href="/kontakt/" class="bg-white/10 hover:bg-white/20 px-8 py-4 rounded-md font-bold text-lg transition-colors">Weiterbildungsplan erstellen</a>
        <a href="/kontakt/" class="bg-white/10 hover:bg-white/20 px-8 py-4 rounded-md font-bold text-lg transition-colors">Individuelle Beratung anfragen</a>
      </div>
    </div>
  </section>
</Layout>
