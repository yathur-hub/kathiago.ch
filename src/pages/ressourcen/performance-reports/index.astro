---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Performance Reports">
  <section class="section-spacing bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-6xl mb-6">Performance Reports</h1>
      <p class="text-xl text-slate-600 max-w-2xl">
        Willkommen auf der Seite für Performance Reports. Hier finden Sie in Kürze detaillierte Informationen.
      </p>
    </div>
  </section>

  <section class="section-spacing">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="p-12 bg-white border border-slate-100 rounded-3xl text-center">
        <h2 class="text-2xl mb-4">Inhalt folgt</h2>
        <p class="text-slate-500 mb-8">Diese Seite befindet sich aktuell im Aufbau.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn-secondary">Zur Startseite</a>
          <a href="/ressourcen/" class="btn-primary">Zurück zur Übersicht</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
